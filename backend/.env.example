# Môi trường chạy dự án (development hoặc production)
NODE_ENV=development

# Cổng khởi chạy Backend Server
PORT=5000

# Đường dẫn kết nối MongoDB
MONGO_URI=mongodb://localhost:27017/opticontent

# Khóa bí mật JWT dùng để mã hóa token đăng nhập
JWT_SECRET=your_super_secret_jwt_key_here

# API Key lấy từ Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Cấu hình SMTP Email để gửi email đặt lại mật khẩu
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=OptiContent <your-email@gmail.com>

# URL Frontend (dùng để tạo link reset password trong email)
FRONTEND_URL=http://localhost:5173
